# PostgreSQL
POSTGRES_USER=clinic
POSTGRES_PASSWORD=clinic_pass
POSTGRES_DB=clinic_db

# Generate with: openssl rand -hex 32
JWT_SECRET=

# Shared secret between backend and Telegram bot.
# Generate with: openssl rand -hex 32
# Must be the same value in both backend and bot services.
BOT_API_SECRET=

# Telegram bot token from @BotFather
BOT_TOKEN=
